{
  "expo": {
    "name": "Samikaran Olympiad",
    "slug": "samikaran-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "samikaran",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0D0A1E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.samikaran.olympiad"
    },
    "android": {
      "package": "com.samikaran.olympiad",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0D0A1E"
      },
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5b21b6",
          "androidMode": "default",
          "androidCollapsedTitle": "Samikaran Olympiad"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for exam proctoring.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice questions."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice answer recording."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
